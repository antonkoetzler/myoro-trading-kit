# Polymarket (wallet-derived API key; SDK can create/derive)
# PRIVATE_KEY=

# Proxy (Safe) address so orders show under your Polymarket profile
# FUNDER_ADDRESS=

# Optional: pre-derived CLOB API credentials (e.g. from OpenClaw)
# API_KEY=
# API_SECRET=
# API_PASSPHRASE=

# Binance (optional; data-only WS often needs no key)
# BINANCE_API_KEY=

# Copy trading: list in copy_traders.txt (one 0x address per line). Or set path:
# COPY_TRADERS_FILE=path/to/copy_traders.txt
# Poll interval in ms (default 250). COPY_POLL_MS=250

# Paper-trading bankroll (number, for display)
# PAPER_BANKROLL=10000

# Mode: paper | live
# EXECUTION_MODE=paper
