# Polymarket (wallet-derived API key; SDK can create/derive)
PRIVATE_KEY=

# Proxy (Safe) address so orders show under your Polymarket profile
FUNDER_ADDRESS=

# Optional: pre-derived CLOB API credentials (e.g. from OpenClaw)
API_KEY=
API_SECRET=
API_PASSPHRASE=

# Binance (optional; data-only WS often needs no key)
BINANCE_API_KEY=

# BallDontLie API
BALLDONTLIE_KEY=
